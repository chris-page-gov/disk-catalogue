# Output artefacts
# Ignore everything under output/ at any depth (generated scan results)
/output/
# Explicit patterns retained for clarity
/output/**/*.csv
/output/**/*.parquet
/catalogue.duckdb*

# Local data dumps
*.dump
*.bak
# Local drive manifest(s) — untracked, machine-specific
/drive_manifest.csv
/drives_manifest.csv
# Ignore any drive_manifest*.csv variants at root, except the template
/drive_manifest*.csv
!/drive_manifest.template.csv

# Temporary
/tmp/
*.swp
~$*

# Node (if any future UI work adds it)
node_modules/

# Coverage reports
coverage.xml

# Lock files (uv generates .venv, but keep optional)
/uv.lock
pm-debug.log*

